#include <input/processors.dtsi>
#include <dt-bindings/zmk/zip_dynamic_scale.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

#define DEFAULT_LAYER   0
#define SECONDARY_LAYER 1
#define TERTIARY_LAYER  2
#define SYSTEM_LAYER    3

&mt { quick-tap-ms = <200>; };

&lt { quick-tap-ms = <200>; };

/ {
    behaviors {
        scroll_scale: scroll_scale {
            compatible = "zmk,behavior-scroll-scale";
            scroll_scale = <35>;
        };

        zip_dyn_scale: zip_dyn_scale {
            compatible = "zmk,behavior-zip-dynamic-scale";
            #binding-cells = <2>;
        };

        zip_dyn_scale_set: zip_dyn_scale_set {
            compatible = "zmk,behavior-zip-dynamic-scale-set";
            #binding-cells = <2>;
        };

        mt2: mod_tap2 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <125>;
            bindings = <&kp>, <&kp>;
        };

        tap_dance_layer_1and2: tap_dance_layer_1and2 {
            compatible = "zmk,behavior-tap-dance";
            label = "td_mo12";
            #binding-cells = <0>;
            bindings = <&mo 1>, <&mo 2>;
        };
    };

    combos {
        compatible = "zmk,combos";

        CONBO_ESC {
            bindings = <&kp ESCAPE>;
            key-positions = <0 1>;
        };

        COMBO_TAB {
            bindings = <&kp TAB>;
            key-positions = <10 11>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        DEFAULT_LAYER {
            display-name = "Default";
            bindings = <
&kp Q              &kp W      &kp E              &kp R      &kp T                                     &kp Y          &kp U      &kp I           &kp O           &mt2 LEFT_BRACKET P
&kp A              &kp S      &kp D              &kp F      &kp G                                     &kp H          &kp J      &kp K           &kp L           &mt2 EQUAL MINUS
&mt2 LEFT_SHIFT Z  &kp X      &kp C              &kp V      &kp B                                     &kp N          &kp M      &kp COMMA       &kp PERIOD      &kp SLASH
&kp LCTRL          &kp LWIN   &kp LEFT_ALT       &mo 1      &kp SPACE         &kp LEFT_SHIFT  &mo 2   &kp BACKSPACE  &kp ENTER  &kp LANGUAGE_2  &kp LANGUAGE_1  &kp INTERNATIONAL_1
                   &none      &kp LS(LG(RIGHT))  &kp DOWN   &kp LG(LS(LEFT))  &kp LG(UP)      &kp UP  &kp LEFT       &kp DOWN   &kp RIGHT       &none
&mkp LCLK          &mkp RCLK  &mkp MCLK                                                                                         &mkp LCLK       &mkp RCLK       &mkp MCLK
&mkp MB4           &mkp MB5   &kp LG(TAB)        &kp LG(D)  &kp LCTRL                                 &mkp MB4       &mkp MB5   &kp LG(TAB)     &kp LG(D)       &kp LCTRL
            >;
        };

        SECONDARY_LAYER {
            display-name = "secondary_layer";
            bindings = <
&trans            &kp PAGE_UP        &kp UP_ARROW  &kp PAGE_DOWN      &trans                   &trans            &kp NUMBER_7       &kp NUMBER_8  &kp NUMBER_9  &trans
&kp HOME          &kp LEFT           &kp DOWN      &kp RIGHT          &kp END                  &trans            &kp NUMBER_4       &kp NUMBER_5  &kp NUMBER_6  &mt COLON SEMI
&kp LEFT_SHIFT    &kp LS(LG(LEFT))   &kp LG(F8)    &kp LS(LG(RIGHT))  &trans                   &kp NUMBER_0      &kp NUMBER_1       &kp NUMBER_2  &kp NUMBER_3  &kp SLASH
&trans            &trans             &trans        &trans             &trans   &trans  &trans  &kp BACKSPACE     &kp ENTER          &kp COMMA     &kp PERIOD    &trans
                  &trans             &trans        &trans             &trans   &trans  &trans  &trans            &trans             &trans        &trans
&trans            &trans             &trans                                                                                         &trans        &trans        &trans
&kp LC(LG(LEFT))  &kp LC(LG(RIGHT))  &trans        &trans             &trans                   &kp LC(LG(LEFT))  &kp LC(LG(RIGHT))  &trans        &trans        &trans
            >;
        };

        TERTIARY_LAYER {
            display-name = "tertiary_layer";
            bindings = <
&kp EXCLAMATION  &kp AT_SIGN    &kp HASH      &kp DOLLAR            &kp PERCENT                            &trans         &kp N7     &kp N8     &kp N9      &trans
&kp CARET        &kp AMPERSAND  &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS                  &trans         &kp N4     &kp N5     &kp N6      &trans
&kp GRAVE        &kp SQT        &kp SEMI      &kp LEFT_BRACKET      &kp RIGHT_BRACKET                      &kp N0         &kp N1     &kp N2     &kp N3      &trans
&trans           &trans         &trans        &trans                &trans                 &trans  &trans  &kp BACKSPACE  &kp ENTER  &kp COMMA  &kp PERIOD  &trans
                 &trans         &trans        &trans                &trans                 &trans  &trans  &trans         &trans     &trans     &trans
&trans           &trans         &trans                                                                                               &trans     &trans      &trans
&trans           &trans         &trans        &trans                &trans                                 &trans         &trans     &trans     &trans      &trans
            >;
        };

        SYSTEM_LAYER {
            display-name = "system_layer";
            bindings = <
&kp F1   &kp F2   &kp F3   &kp F4   &kp F5                   &out OUT_TOG                   &bt BT_SEL 0                   &bt BT_SEL 1                   &bt BT_SEL 2                   &bt BT_SEL 3
&kp F6   &kp F7   &kp F8   &kp F9   &kp F10                  &sys_reset                     &bootloader                    &bt BT_CLR                     &bt BT_CLR_ALL                 &trans
&kp F11  &kp F12  &kp F13  &kp F14  &kp F15                  &zip_dyn_scale ZDS_XY ZDS_INC  &zip_dyn_scale ZDS_XY ZDS_DEC  &zip_dyn_scale ZDS_SC ZDS_INC  &zip_dyn_scale ZDS_SC ZDS_DEC  &zip_dyn_scale ZDS_ALL ZDS_RST
&trans   &trans   &trans   &trans   &trans   &trans  &trans  &trans                         &trans                         &trans                         &trans                         &trans
         &trans   &trans   &trans   &trans   &trans  &trans  &trans                         &trans                         &trans                         &trans
&trans   &trans   &trans                                                                                                   &trans                         &trans                         &trans
&trans   &trans   &trans   &trans   &trans                   &trans                         &trans                         &trans                         &trans                         &trans
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        Cond_Syslayer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
